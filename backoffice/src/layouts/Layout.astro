interface Props {
  title: string;
  showSidebar?: boolean;
}

const { title, showSidebar = true } = Astro.props;

const currentPath = new URL(Astro.request.url).pathname;

const navItems = [
  { href: '/dashboard', label: 'Dashboard', icon: 'dashboard' },
  { href: '/content/texts', label: 'Testi', icon: 'forms' },
  { href: '/content/audio', label: 'Audio', icon: 'audio' },
  { href: '/content/photos', label: 'Foto', icon: 'images' },
  { href: '/content/stickers', label: 'Sticker', icon: 'sticker' },
  { href: '/categories', label: 'Categorie', icon: 'folder' },
  { href: '/groups', label: 'Gruppi', icon: 'users' },
  { href: '/scheduler', label: 'Scheduler', icon: 'calendar' },
  { href: '/logs', label: 'Log', icon: 'table' },
  { href: '/settings', label: 'Impostazioni', icon: 'settings' },
];

