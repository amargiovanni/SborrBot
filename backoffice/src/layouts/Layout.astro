<!DOCTYPE html>
<html lang="it" x-data="{ darkMode: localStorage.getItem('darkMode') === 'true', sidebarToggle: false }" x-init="$watch('darkMode', val => localStorage.setItem('darkMode', val))" :class="{ 'dark': darkMode }">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} - SborrBot Admin</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🤖</text></svg>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet" />
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <slot name="head" />
</head>
<body class="min-h-screen font-outfit bg-gray-50 dark:bg-gray-950">
  {showSidebar ? (
    <div class="flex min-h-screen">
      <!-- Overlay for mobile sidebar -->
      <div
        x-show="sidebarToggle"
        x-transition:enter="transition-opacity ease-linear duration-300"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition-opacity ease-linear duration-300"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        class="fixed inset-0 z-9999 bg-black/40 lg:hidden"
        @click="sidebarToggle = false"
      ></div>

      <!-- Sidebar -->
      <aside
        :class="sidebarToggle ? 'translate-x-0' : '-translate-x-full'"
        class="fixed left-0 top-0 z-99999 flex h-screen w-[290px] flex-col overflow-y-hidden border-r border-gray-200 bg-white px-5 dark:border-gray-800 dark:bg-gray-900 lg:static lg:translate-x-0 transition-transform duration-300"
      >
        <!-- Sidebar Header -->
        <div class="flex items-center justify-between pt-8 pb-7">
          <a href="/dashboard" class="flex items-center gap-2">
            <span class="text-2xl">🤖</span>
            <div>
              <span class="text-lg font-semibold text-gray-900 dark:text-white">SborrBot</span>
              <span class="block text-xs text-gray-400 dark:text-gray-500">Admin Panel</span>
            </div>
          </a>
          <button class="lg:hidden text-gray-500 dark:text-gray-400" @click="sidebarToggle = false">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="fill-current">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M6.21967 7.28131C5.92678 6.98841 5.92678 6.51354 6.21967 6.22065C6.51256 5.92775 6.98744 5.92775 7.28033 6.22065L11.999 10.9393L16.7176 6.22078C17.0105 5.92789 17.4854 5.92788 17.7782 6.22078C18.0711 6.51367 18.0711 6.98855 17.7782 7.28144L13.0597 12L17.7782 16.7186C18.0711 17.0115 18.0711 17.4863 17.7782 17.7792C17.4854 18.0721 17.0105 18.0721 16.7176 17.7792L11.999 13.0607L7.28033 17.7794C6.98744 18.0722 6.51256 18.0722 6.21967 17.7794C5.92678 17.4865 5.92678 17.0116 6.21967 16.7187L10.9384 12L6.21967 7.28131Z" fill="" />
            </svg>
          </button>
        </div>

        <!-- Sidebar Navigation -->
        <div class="flex flex-col overflow-y-auto no-scrollbar">
          <nav>
            <h3 class="mb-4 text-xs font-medium uppercase leading-5 text-gray-400">Menu</h3>
            <ul class="flex flex-col gap-1 mb-6">
              {navItems.map(item => {
                const isActive = currentPath.startsWith(item.href);
                return (
                  <li>
                    <a
                      href={item.href}
                      class={`menu-item ${isActive ? 'menu-item-active' : 'menu-item-inactive'}`}
                    >
                      <svg class="menu-item-icon w-6 h-6 flex-shrink-0" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <Fragment set:html={svgIcons[item.icon] || ''} />
                      </svg>
                      <span>{item.label}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </nav>
        </div>
      </aside>

      <!-- Main Content Area -->
      <div class="flex-1 flex flex-col overflow-hidden">
        <!-- Header -->
        <header class="sticky top-0 z-99 flex w-full border-b border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900">
          <div class="flex grow items-center justify-between px-4 py-3 lg:px-6 lg:py-4">
            <div class="flex items-center gap-4">
              <!-- Hamburger Toggle -->
              <button
                class="flex h-10 w-10 items-center justify-center rounded-lg border border-gray-200 text-gray-500 lg:hidden dark:border-gray-800 dark:text-gray-400"
                @click.stop="sidebarToggle = !sidebarToggle"
              >
                <svg class="fill-current" width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M3.25 6C3.25 5.58579 3.58579 5.25 4 5.25L20 5.25C20.4142 5.25 20.75 5.58579 20.75 6C20.75 6.41421 20.4142 6.75 20 6.75L4 6.75C3.58579 6.75 3.25 6.41422 3.25 6ZM3.25 18C3.25 17.5858 3.58579 17.25 4 17.25L20 17.25C20.4142 17.25 20.75 17.5858 20.75 18C20.75 18.4142 20.4142 18.75 20 18.75L4 18.75C3.58579 18.75 3.25 18.4142 3.25 18ZM4 11.25C3.58579 11.25 3.25 11.5858 3.25 12C3.25 12.4142 3.58579 12.75 4 12.75L12 12.75C12.4142 12.75 12.75 12.4142 12.75 12C12.75 11.5858 12.4142 11.25 12 11.25L4 11.25Z" fill="" />
                </svg>
              </button>

              <!-- Search -->
              <div class="hidden lg:block">
                <button
                  id="search-trigger"
                  class="relative flex items-center"
                >
                  <span class="absolute left-4 top-1/2 -translate-y-1/2">
                    <svg class="fill-gray-500 dark:fill-gray-400" width="20" height="20" viewBox="0 0 20 20" fill="none">
                      <path fill-rule="evenodd" clip-rule="evenodd" d="M3.04175 9.37363C3.04175 5.87693 5.87711 3.04199 9.37508 3.04199C12.8731 3.04199 15.7084 5.87693 15.7084 9.37363C15.7084 12.8703 12.8731 15.7053 9.37508 15.7053C5.87711 15.7053 3.04175 12.8703 3.04175 9.37363ZM9.37508 1.54199C5.04902 1.54199 1.54175 5.04817 1.54175 9.37363C1.54175 13.6991 5.04902 17.2053 9.37508 17.2053C11.2674 17.2053 13.003 16.5344 14.357 15.4176L17.177 18.238C17.4699 18.5309 17.9448 18.5309 18.2377 18.238C18.5306 17.9451 18.5306 17.4703 18.2377 17.1774L15.418 14.3573C16.5365 13.0033 17.2084 11.2669 17.2084 9.37363C17.2084 5.04817 13.7011 1.54199 9.37508 1.54199Z" fill="" />
                    </svg>
                  </span>
                  <span class="h-11 w-full rounded-lg border border-gray-200 bg-transparent py-2.5 pr-14 pl-12 text-sm text-gray-400 dark:border-gray-800 dark:text-white/30 xl:w-[430px] flex items-center">
                    Cerca o digita un comando...
                  </span>
                  <span class="absolute top-1/2 right-2.5 -translate-y-1/2 inline-flex items-center gap-0.5 rounded-lg border border-gray-200 bg-gray-50 px-[7px] py-[4.5px] text-xs text-gray-500 dark:border-gray-800 dark:bg-white/[0.03] dark:text-gray-400">
                    <span>&#8984;</span>
                    <span>K</span>
                  </span>
                </button>
              </div>
            </div>

            <div class="flex items-center gap-3">
              <!-- Dark Mode Toggle -->
              <button
                class="relative flex h-11 w-11 items-center justify-center rounded-full border border-gray-200 bg-white text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-700 dark:border-gray-800 dark:bg-gray-900 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white"
                @click.prevent="darkMode = !darkMode"
              >
                <!-- Sun icon (shown in dark mode) -->
                <svg x-show="darkMode" class="fill-current" width="20" height="20" viewBox="0 0 20 20" fill="none">
