---
import Layout from '../layouts/Layout.astro';
import { getCategories } from '../lib/db';

const env = (Astro.locals as any).runtime?.env;
let categories: any[] = [];

if (env?.DB) {
  const result = await getCategories(env.DB);
  categories = result.results ?? [];
}

const typeConfig: Record<string, { label: string; icon: string; color: string }> = {
  text: { label: 'Testo', icon: '📝', color: 'blue' },
  audio: { label: 'Audio', icon: '🔊', color: 'purple' },
  photo: { label: 'Foto', icon: '📸', color: 'pink' },
  sticker: { label: 'Sticker', icon: '🎨', color: 'amber' },
};

const grouped = Object.entries(typeConfig).map(([type, config]) => ({
  type,
  ...config,
  items: categories.filter((c: any) => c.type === type),
}));
---

<Layout title="Categorie">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-semibold text-gray-800 dark:text-white/90">Gestione Categorie</h1>
        <p class="text-theme-sm text-gray-500 dark:text-gray-400 mt-1">{categories.length} categorie totali</p>
      </div>
      <button id="btn-new" class="btn-primary">
        + Nuova Categoria
      </button>
    </div>

    {grouped.map(group => (
      <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03] overflow-hidden">
        <div class="px-5 py-4 border-b border-gray-200 dark:border-gray-800 flex items-center justify-between md:px-6">
          <h2 class="text-lg font-semibold text-gray-800 dark:text-white/90 flex items-center gap-2">
            <span>{group.icon}</span>
            <span>{group.label}</span>
            <span class="text-theme-xs text-gray-400 dark:text-gray-500 font-normal ml-1">({group.items.length})</span>
          </h2>
        </div>
        {group.items.length > 0 ? (
          <div class="divide-y divide-gray-200 dark:divide-gray-800">
            {group.items.map((cat: any) => (
              <div class="rounded-lg px-4 py-3 hover:bg-gray-100 dark:hover:bg-white/5 transition-colors group flex items-center gap-4 mx-1 md:mx-2">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2">
                    <span class="text-theme-sm font-medium text-gray-800 dark:text-white/90">{cat.name}</span>
                    <code class="rounded-md bg-gray-100 px-2 py-0.5 text-theme-xs font-medium text-gray-500 dark:bg-gray-800 dark:text-gray-400">{cat.slug}</code>
                    {!cat.is_active && (
                      <span class="rounded-full bg-error-50 px-2 py-0.5 text-theme-xs font-medium text-error-600 dark:bg-error-500/15 dark:text-error-500">Disattivata</span>
                    )}
                  </div>
                  {cat.description && (
                    <p class="text-theme-xs text-gray-500 dark:text-gray-400 mt-0.5">{cat.description}</p>
                  )}
                </div>
                <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                  <button data-edit={JSON.stringify({ id: cat.id, name: cat.name, description: cat.description || '', is_active: cat.is_active })}
                    class="btn-secondary text-theme-xs px-2.5 py-1">
                    Modifica
                  </button>
                  <button data-toggle={cat.id} data-active={cat.is_active}
                    class={`text-theme-xs px-2.5 py-1 rounded-lg font-medium transition-colors ${cat.is_active ? 'text-warning-600 dark:text-warning-400 bg-warning-50 dark:bg-warning-500/15 hover:bg-warning-100 dark:hover:bg-warning-500/25' : 'text-success-600 dark:text-success-400 bg-success-50 dark:bg-success-500/15 hover:bg-success-100 dark:hover:bg-success-500/25'}`}>
                    {cat.is_active ? 'Disattiva' : 'Attiva'}
                  </button>
                  <button data-delete={cat.id} data-name={cat.name}
                    class="btn-danger text-theme-xs px-2.5 py-1">
                    Elimina
                  </button>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="px-5 py-6 text-center text-theme-sm text-gray-500 dark:text-gray-400 md:px-6">Nessuna categoria di tipo {group.label.toLowerCase()}</div>
        )}
      </div>
    ))}
  </div>

  <!-- Modal Nuova/Modifica Categoria -->
  <div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
    <div class="rounded-2xl border border-gray-200 bg-white shadow-theme-xl dark:border-gray-800 dark:bg-gray-900 w-full max-w-md mx-4 p-5 md:p-6">
      <h3 id="modal-title" class="text-lg font-semibold text-gray-800 dark:text-white/90 mb-4">Nuova Categoria</h3>
      <form id="catForm" class="space-y-4">
        <input type="hidden" name="id" />
        <div>
          <label class="block text-theme-xs text-gray-500 dark:text-gray-400 mb-1.5 font-medium">Nome</label>
          <input type="text" name="name" required placeholder="Es: Anti-Inter" class="w-full input-field" />
        </div>
        <div id="slug-field">
          <label class="block text-theme-xs text-gray-500 dark:text-gray-400 mb-1.5 font-medium">Slug (identificativo)</label>
          <input type="text" name="slug" required placeholder="es: anti-inter" class="w-full input-field" />
        </div>
        <div id="type-field">
          <label class="block text-theme-xs text-gray-500 dark:text-gray-400 mb-1.5 font-medium">Tipo</label>
          <select name="type" required class="w-full input-field">
            <option value="text">Testo</option>
            <option value="audio">Audio</option>
            <option value="photo">Foto</option>
            <option value="sticker">Sticker</option>
          </select>
        </div>
        <div>
          <label class="block text-theme-xs text-gray-500 dark:text-gray-400 mb-1.5 font-medium">Descrizione (opzionale)</label>
          <input type="text" name="description" placeholder="Descrizione breve" class="w-full input-field" />
        </div>
        <div class="flex items-center gap-3 pt-2">
          <button type="submit" class="btn-primary flex-1">Salva</button>
          <button type="button" id="btn-cancel" class="btn-secondary flex-1">Annulla</button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline>
    (function() {
      var modal = document.getElementById('modal');
      var form = document.getElementById('catForm');
      var isEditing = false;

      function openModal(editData) {
        isEditing = !!editData;
        document.getElementById('modal-title').textContent = isEditing ? 'Modifica Categoria' : 'Nuova Categoria';
        document.getElementById('slug-field').style.display = isEditing ? 'none' : '';
        document.getElementById('type-field').style.display = isEditing ? 'none' : '';

        if (editData) {
          form.id_field.value = editData.id;
          form.name.value = editData.name;
          form.description.value = editData.description;
        } else {
          form.reset();
          form.id_field.value = '';
        }

        modal.classList.remove('hidden');
        modal.classList.add('flex');
        form.name.focus();
      }

      function closeModal() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }

      // Fix: use data attribute name for hidden input
      form.id_field = form.querySelector('input[name="id"]');

      document.getElementById('btn-new').addEventListener('click', function() { openModal(null); });
      document.getElementById('btn-cancel').addEventListener('click', closeModal);
      modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });

      // Auto-generate slug from name (only for new categories)
      form.name.addEventListener('input', function() {
        if (!isEditing) {
          form.slug.value = form.name.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
        }
      });

      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        var id = form.id_field.value;
        var url = '/api/categories';
        var method = id ? 'PUT' : 'POST';
        var body = id
          ? { id: Number(id), name: form.name.value, description: form.description.value }
          : { name: form.name.value, slug: form.slug.value, type: form.type.value, description: form.description.value };

        var res = await fetch(url, { method: method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
        if (res.ok) {
          window.location.reload();
        } else {
          var data = await res.json();
          alert(data.error || 'Errore');
        }
      });

      // Toggle active
      document.querySelectorAll('[data-toggle]').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var id = Number(btn.getAttribute('data-toggle'));
          var active = btn.getAttribute('data-active') === '1';
          var res = await fetch('/api/categories', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: id, is_active: !active }),
          });
          if (res.ok) window.location.reload();
        });
      });

      // Edit
      document.querySelectorAll('[data-edit]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var data = JSON.parse(btn.getAttribute('data-edit'));
          openModal(data);
        });
      });

      // Delete
      document.querySelectorAll('[data-delete]').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var name = btn.getAttribute('data-name');
          if (!confirm('Eliminare la categoria "' + name + '"?\nFunziona solo se la categoria e vuota.')) return;
          var res = await fetch('/api/categories?id=' + btn.getAttribute('data-delete'), { method: 'DELETE' });
          if (res.ok) {
            window.location.reload();
          } else {
            var data = await res.json();
            alert(data.error || 'Errore');
          }
        });
      });
    })();
  </script>
</Layout>
