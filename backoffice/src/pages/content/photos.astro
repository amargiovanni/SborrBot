---
import Layout from '../../layouts/Layout.astro';
import { getCategoriesWithCounts, getMediaItems } from '../../lib/db';

const env = (Astro.locals as any).runtime?.env;
const url = new URL(Astro.request.url);
const categoryId = Number(url.searchParams.get('category')) || 0;
const page = Number(url.searchParams.get('page')) || 1;

let categories: any[] = [];
let items: any[] = [];
let total = 0;
let selectedCategory: any = null;

if (env?.DB) {
  const catResult = await getCategoriesWithCounts(env.DB, 'photo');
  categories = catResult.results ?? [];
  if (categoryId) {
    selectedCategory = categories.find((c: any) => c.id === categoryId);
    const result = await getMediaItems(env.DB, categoryId, page);
    items = result.items as any[];
    total = result.total;
  } else if (categories.length > 0) {
    return Astro.redirect(`/content/photos?category=${categories[0].id}`);
  }
}

const totalPages = Math.ceil(total / 20);

function formatSize(bytes: number | null) {
  if (!bytes) return 'N/A';
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1048576) return Math.round(bytes / 1024) + ' KB';
  return (bytes / 1048576).toFixed(1) + ' MB';
}

function formatDate(dateStr: string) {
  try {
    const d = new Date(dateStr + 'Z');
    return d.toLocaleDateString('it-IT', { day: 'numeric', month: 'short', year: 'numeric' });
  } catch { return dateStr; }
}
---

<Layout title="Foto">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-semibold text-gray-800 dark:text-white/90">Gestione Foto</h1>
      <p class="text-theme-sm text-gray-500 dark:text-gray-400 mt-1">Foto per ogni categoria</p>
    </div>

    <div class="flex gap-6 min-h-[600px]">
      <!-- Sidebar categorie -->
      <div class="w-56 flex-shrink-0">
        <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03] sticky top-6">
          <div class="p-3 border-b border-gray-200 dark:border-gray-800">
            <input type="text" id="catSearch" placeholder="Cerca categoria..." class="input-field !py-2 text-sm" />
          </div>
          <nav class="p-2 max-h-[520px] overflow-y-auto" id="catList">
            {categories.map((cat: any) => (
              <a
                href={`/content/photos?category=${cat.id}`}
                data-cat-name={cat.name.toLowerCase()}
                class={`flex items-center justify-between px-3 py-2 rounded-xl text-sm transition-colors ${
                  cat.id === categoryId
                    ? 'bg-brand-50 dark:bg-brand-500/[0.12] text-brand-700 dark:text-brand-400 font-medium'
                    : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800'
                }`}
              >
                <span class="truncate">{cat.name}</span>
                <span class={`text-xs tabular-nums ml-2 flex-shrink-0 ${cat.id === categoryId ? 'text-brand-500 dark:text-brand-400' : 'text-gray-400 dark:text-gray-500'}`}>{cat.item_count}</span>
              </a>
            ))}
          </nav>
        </div>
      </div>

      <!-- Contenuto -->
      <div class="flex-1 min-w-0">
        {selectedCategory ? (
          <div class="space-y-4">
            <div>
              <h2 class="text-lg font-semibold text-gray-800 dark:text-white/90">{selectedCategory.name}</h2>
              <p class="text-theme-sm text-gray-500 dark:text-gray-400">{total} file</p>
            </div>

            <!-- Upload form -->
            <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03] md:p-6">
              <form id="uploadForm" enctype="multipart/form-data" class="flex gap-3 items-end flex-wrap">
                <div class="flex-1 min-w-[200px]">
                  <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">File immagine (jpg, png, gif)</label>
                  <input type="file" name="file" accept="image/*" class="w-full text-sm text-gray-600 dark:text-gray-300 file:mr-3 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-medium file:bg-brand-500 file:text-white hover:file:bg-brand-600 file:cursor-pointer" />
                </div>
                <div>
                  <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Didascalia (opzionale)</label>
                  <input type="text" name="caption" placeholder="Didascalia" class="input-field" />
                </div>
                <button type="submit" class="btn-primary whitespace-nowrap">Carica</button>
              </form>
              <div id="uploadStatus" class="hidden mt-3 text-sm px-3 py-2 rounded-xl"></div>
            </div>

            <!-- Gallery -->
            <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03] overflow-hidden">
              {items.length > 0 ? (
                <>
                  <!-- View toggle -->
                  <div class="px-4 py-2.5 border-b border-gray-200 dark:border-gray-800 flex items-center justify-end">
                    <div class="flex items-center gap-1 bg-gray-100 dark:bg-gray-800 rounded-lg p-0.5">
                      <button id="view-grid" class="px-2.5 py-1 text-xs rounded-md bg-white dark:bg-gray-700 text-gray-800 dark:text-white/90 shadow-sm transition-all">Griglia</button>
                      <button id="view-list" class="px-2.5 py-1 text-xs rounded-md text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-all">Lista</button>
                    </div>
                  </div>

                  <!-- Grid view (default) -->
                  <div id="grid-view" class="p-4 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
                    {items.map((item: any) => (
                      <div class="group relative rounded-xl overflow-hidden border border-gray-200 dark:border-gray-800 bg-gray-100 dark:bg-gray-800/50 aspect-square">
                        <img
                          src={`/api/content/serve-media?id=${item.id}`}
                          alt={item.caption || item.file_name}
                          loading="lazy"
                          class="w-full h-full object-cover"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                          <div class="absolute bottom-0 left-0 right-0 p-3">
                            <p class="text-white text-xs font-medium truncate">{item.caption || item.file_name}</p>
                            <div class="flex items-center gap-2 mt-1">
                              <span class="text-white/50 text-[10px]">{formatSize(item.file_size)}</span>
                              {item.telegram_file_id && <span class="text-[10px] text-green-300">Cached</span>}
                            </div>
                          </div>
                          <button data-delete={item.id} data-r2key={item.r2_key}
                            class="absolute top-2 right-2 w-7 h-7 flex items-center justify-center rounded-full bg-red-500/80 text-white text-sm hover:bg-red-600 transition-colors">
                            &times;
                          </button>
                        </div>
                      </div>
                    ))}
                  </div>

                  <!-- List view -->
                  <div id="list-view" class="hidden divide-y divide-gray-200 dark:divide-gray-800">
                    {items.map((item: any) => (
                      <div class="p-4 hover:bg-gray-50 dark:hover:bg-gray-800/30 transition-colors group">
                        <div class="flex items-center gap-3">
                          <img src={`/api/content/serve-media?id=${item.id}`} alt="" loading="lazy" class="w-12 h-12 rounded-xl object-cover flex-shrink-0 bg-gray-100 dark:bg-gray-800" />
                          <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-gray-800 dark:text-white/90 truncate">{item.caption || item.file_name}</p>
                            <div class="flex items-center gap-2 mt-1 flex-wrap">
                              <span class="text-xs text-gray-400 dark:text-gray-500">{item.file_name}</span>
                              <span class="text-gray-300 dark:text-gray-600">&middot;</span>
                              <span class="text-xs text-gray-400 dark:text-gray-500">{formatSize(item.file_size)}</span>
                              <span class="text-gray-300 dark:text-gray-600">&middot;</span>
                              <span class="text-xs text-gray-400 dark:text-gray-500">{formatDate(item.created_at)}</span>
                            </div>
                          </div>
                          <span class={`text-xs px-2 py-1 rounded-lg font-medium flex-shrink-0 ${item.telegram_file_id ? 'bg-green-50 dark:bg-green-900/30 text-green-600 dark:text-green-400' : 'bg-yellow-50 dark:bg-yellow-900/30 text-yellow-600 dark:text-yellow-400'}`}>
                            {item.telegram_file_id ? 'Cached' : 'Non cached'}
                          </span>
                          <button data-delete={item.id} data-r2key={item.r2_key} class="text-xs px-2.5 py-1 rounded-lg text-red-500 dark:text-red-400 bg-red-50 dark:bg-red-950/50 hover:bg-red-100 dark:hover:bg-red-900/40 transition-colors opacity-0 group-hover:opacity-100 flex-shrink-0">Elimina</button>
                        </div>
                      </div>
                    ))}
                  </div>
                </>
              ) : (
                <div class="p-12 text-center">
                  <div class="text-4xl mb-3">📸</div>
                  <p class="text-gray-500 dark:text-gray-400 font-medium">Nessuna foto in questa categoria</p>
                  <p class="text-gray-400 dark:text-gray-500 text-sm mt-1">Caricane una usando il form qui sopra</p>
                </div>
              )}

              {totalPages > 1 && (
                <div class="p-4 border-t border-gray-200 dark:border-gray-800 flex items-center justify-between">
                  <span class="text-gray-500 dark:text-gray-400 text-sm">{total} file</span>
                  <div class="flex items-center gap-2">
                    {page > 1 && <a href={`/content/photos?category=${categoryId}&page=${page - 1}`} class="px-3 py-1.5 text-sm bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">&larr; Prec</a>}
                    <span class="px-3 py-1.5 text-sm text-gray-500 dark:text-gray-400 tabular-nums">{page}/{totalPages}</span>
                    {page < totalPages && <a href={`/content/photos?category=${categoryId}&page=${page + 1}`} class="px-3 py-1.5 text-sm bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">Succ &rarr;</a>}
                  </div>
                </div>
              )}
            </div>
          </div>
        ) : (
          <div class="flex items-center justify-center h-64">
            <p class="text-gray-400 dark:text-gray-500">Seleziona una categoria dalla sidebar</p>
          </div>
        )}
      </div>
    </div>
  </div>

  <script define:vars={{ categoryId }}>
    document.getElementById('catSearch')?.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      document.querySelectorAll('#catList a').forEach(el => {
        el.style.display = (el.getAttribute('data-cat-name') || '').includes(query) ? '' : 'none';
      });
    });

    // View toggle (grid/list)
    const gridBtn = document.getElementById('view-grid');
    const listBtn = document.getElementById('view-list');
    const gridView = document.getElementById('grid-view');
    const listView = document.getElementById('list-view');
    if (gridBtn && listBtn && gridView && listView) {
      const activeClass = 'bg-white dark:bg-gray-700 text-gray-800 dark:text-white/90 shadow-sm';
      const inactiveClass = 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200';
      gridBtn.addEventListener('click', () => {
        gridView.classList.remove('hidden'); listView.classList.add('hidden');
        gridBtn.className = 'px-2.5 py-1 text-xs rounded-md transition-all ' + activeClass;
        listBtn.className = 'px-2.5 py-1 text-xs rounded-md transition-all ' + inactiveClass;
      });
      listBtn.addEventListener('click', () => {
        listView.classList.remove('hidden'); gridView.classList.add('hidden');
        listBtn.className = 'px-2.5 py-1 text-xs rounded-md transition-all ' + activeClass;
        gridBtn.className = 'px-2.5 py-1 text-xs rounded-md transition-all ' + inactiveClass;
      });
    }

    document.getElementById('uploadForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const statusEl = document.getElementById('uploadStatus');
      const formData = new FormData(form);
      formData.append('category_id', String(categoryId));
      statusEl.textContent = 'Caricamento in corso...';
      statusEl.className = 'mt-3 text-sm px-3 py-2 rounded-xl bg-yellow-50 dark:bg-yellow-900/30 text-yellow-600 dark:text-yellow-400';
      const res = await fetch('/api/content/upload', { method: 'POST', body: formData });
      if (res.ok) {
        statusEl.textContent = 'Caricato con successo!';
        statusEl.className = 'mt-3 text-sm px-3 py-2 rounded-xl bg-green-50 dark:bg-green-900/30 text-green-600 dark:text-green-400';
        setTimeout(() => window.location.reload(), 1000);
      } else {
        const data = await res.json();
        statusEl.textContent = data.error || 'Errore durante il caricamento';
        statusEl.className = 'mt-3 text-sm px-3 py-2 rounded-xl bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400';
      }
    });

    document.querySelectorAll('[data-delete]').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Eliminare questa foto?')) return;
        const res = await fetch(`/api/content/media?id=${btn.getAttribute('data-delete')}`, { method: 'DELETE' });
        if (res.ok) window.location.reload();
      });
    });
  </script>
</Layout>
