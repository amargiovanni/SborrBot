---
import Layout from '../../layouts/Layout.astro';
import { getCategoriesWithCounts, getTextResponses } from '../../lib/db';

const env = (Astro.locals as any).runtime?.env;
const url = new URL(Astro.request.url);
const categoryId = Number(url.searchParams.get('category')) || 0;
const page = Number(url.searchParams.get('page')) || 1;

let categories: any[] = [];
let items: any[] = [];
let total = 0;
let selectedCategory: any = null;

if (env?.DB) {
  const catResult = await getCategoriesWithCounts(env.DB, 'text');
  categories = catResult.results ?? [];
  if (categoryId) {
    selectedCategory = categories.find((c: any) => c.id === categoryId);
    const result = await getTextResponses(env.DB, categoryId, page);
    items = result.items as any[];
    total = result.total;
  } else if (categories.length > 0) {
    return Astro.redirect(`/content/texts?category=${categories[0].id}`);
  }
}

const limit = 20;
const totalPages = Math.ceil(total / limit);
const startIndex = (page - 1) * limit;

function formatDate(dateStr: string) {
  try {
    const d = new Date(dateStr + 'Z');
    return d.toLocaleDateString('it-IT', { day: 'numeric', month: 'short', year: 'numeric' });
  } catch { return dateStr; }
}
---

<Layout title="Testi">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-semibold text-gray-800 dark:text-white/90">Gestione Testi</h1>
      <p class="text-theme-sm text-gray-500 dark:text-gray-400 mt-1">Frasi per insulti, minacce, bestemmie, nonno e saluti</p>
    </div>

    <div class="flex gap-6 min-h-[600px]">
      <!-- Sidebar categorie -->
      <div class="w-56 flex-shrink-0">
        <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03] sticky top-6">
          <div class="p-3 border-b border-gray-200 dark:border-gray-800">
            <input
              type="text"
              id="catSearch"
              placeholder="Cerca categoria..."
              class="input-field !py-2 text-sm"
            />
          </div>
          <nav class="p-2 max-h-[520px] overflow-y-auto" id="catList">
            {categories.map((cat: any) => (
              <a
                href={`/content/texts?category=${cat.id}`}
                data-cat-name={cat.name.toLowerCase()}
                class={`flex items-center justify-between px-3 py-2 rounded-xl text-sm transition-colors ${
                  cat.id === categoryId
                    ? 'bg-brand-50 dark:bg-brand-950 text-brand-700 dark:text-brand-400 font-medium'
                    : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800'
                }`}
              >
                <span class="truncate">{cat.name}</span>
                <span class={`text-xs tabular-nums ml-2 flex-shrink-0 ${
                  cat.id === categoryId
                    ? 'text-brand-500 dark:text-brand-400'
                    : 'text-gray-400 dark:text-gray-500'
                }`}>{cat.item_count}</span>
              </a>
            ))}
          </nav>
        </div>
      </div>

      <!-- Contenuto principale -->
      <div class="flex-1 min-w-0">
        {selectedCategory ? (
          <div class="space-y-4">
            <!-- Header categoria -->
            <div class="flex items-center justify-between">
              <div>
                <h2 class="text-lg font-semibold text-gray-800 dark:text-white/90">{selectedCategory.name}</h2>
                <p class="text-theme-sm text-gray-500 dark:text-gray-400">{total} {total === 1 ? 'frase' : 'frasi'}</p>
              </div>
            </div>

            <!-- Form aggiungi -->
            <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03] md:p-6 space-y-3">
              <form id="addForm" class="flex gap-3">
                <input type="hidden" name="category_id" value={categoryId} />
                <input
                  type="text"
                  name="content"
                  id="contentInput"
                  placeholder="Nuova frase... (usa {name} come placeholder per il nome)"
                  class="flex-1 input-field"
                />
                <button type="submit" class="btn-primary whitespace-nowrap">
                  Aggiungi
                </button>
              </form>
              <!-- Telegram Preview -->
              <div id="preview-box" class="hidden">
                <div class="text-theme-sm text-gray-500 dark:text-gray-400 font-medium mb-1.5">Anteprima Telegram:</div>
                <div class="bg-[#1a2236] rounded-xl px-4 py-3 max-w-md">
                  <div class="text-xs text-blue-400 font-medium mb-1">SborrBot</div>
                  <div id="preview-text" class="text-sm text-white/90 leading-relaxed whitespace-pre-wrap"></div>
                </div>
              </div>
              <!-- Bulk import toggle -->
              <div class="flex items-center gap-2 pt-1">
                <button type="button" id="btn-bulk" class="text-xs text-brand-500 dark:text-brand-400 hover:text-brand-600 dark:hover:text-brand-300 font-medium transition-colors">
                  Importa in blocco (CSV/JSON)
                </button>
              </div>
              <!-- Bulk import form -->
              <div id="bulk-form" class="hidden space-y-3 border-t border-gray-200 dark:border-gray-800 pt-3">
                <div class="flex items-center gap-3">
                  <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Formato:</label>
                  <label class="flex items-center gap-1.5 text-sm text-gray-600 dark:text-gray-300">
                    <input type="radio" name="bulkFormat" value="text" checked class="accent-brand-500" /> Una frase per riga
                  </label>
                  <label class="flex items-center gap-1.5 text-sm text-gray-600 dark:text-gray-300">
                    <input type="radio" name="bulkFormat" value="json" class="accent-brand-500" /> JSON array
                  </label>
                </div>
                <textarea
                  id="bulkContent"
                  rows="6"
                  placeholder="Incolla le frasi qui (una per riga)&#10;oppure un array JSON: [&quot;frase 1&quot;, &quot;frase 2&quot;]"
                  class="w-full input-field font-mono text-xs"
                ></textarea>
                <div class="flex items-center justify-between">
                  <span id="bulk-count" class="text-theme-sm text-gray-500 dark:text-gray-400">0 frasi rilevate</span>
                  <button type="button" id="btn-bulk-import" class="btn-primary text-sm">Importa tutto</button>
                </div>
                <div id="bulk-status" class="hidden text-sm px-3 py-2 rounded-xl"></div>
              </div>
            </div>

            <!-- Lista frasi -->
            <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03] overflow-hidden">
              {items.length > 0 ? (
                <div class="divide-y divide-gray-200 dark:divide-gray-800">
                  {items.map((item: any, i: number) => (
                    <div class="p-4 hover:bg-gray-50 dark:hover:bg-gray-800/30 transition-colors group">
                      <div class="flex items-start gap-3">
                        <span class="text-xs text-gray-400 dark:text-gray-500 tabular-nums pt-0.5 w-6 text-right flex-shrink-0">{startIndex + i + 1}.</span>
                        <div class="flex-1 min-w-0">
                          <p class="text-sm text-gray-800 dark:text-white/90 leading-relaxed">{item.content}</p>
                          <p class="text-theme-sm text-gray-500 dark:text-gray-400 mt-1.5">
                            ID: {item.id} &middot; {formatDate(item.created_at)}
                          </p>
                        </div>
                        <button
                          data-delete={item.id}
                          class="btn-danger text-xs !px-2.5 !py-1 opacity-0 group-hover:opacity-100 flex-shrink-0"
                        >
                          Elimina
                        </button>
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <div class="p-12 text-center">
                  <div class="text-4xl mb-3">📝</div>
                  <p class="text-gray-500 dark:text-gray-400 font-medium">Nessuna frase in questa categoria</p>
                  <p class="text-theme-sm text-gray-500 dark:text-gray-400 mt-1">Aggiungine una usando il form qui sopra</p>
                </div>
              )}

              {totalPages > 1 && (
                <div class="p-4 border-t border-gray-200 dark:border-gray-800 flex items-center justify-between">
                  <span class="text-theme-sm text-gray-500 dark:text-gray-400">{total} elementi</span>
                  <div class="flex items-center gap-2">
                    {page > 1 && (
                      <a href={`/content/texts?category=${categoryId}&page=${page - 1}`} class="btn-secondary text-sm !px-3 !py-1.5">
                        &larr; Prec
                      </a>
                    )}
                    <span class="px-3 py-1.5 text-sm text-gray-500 dark:text-gray-400 tabular-nums">{page}/{totalPages}</span>
                    {page < totalPages && (
                      <a href={`/content/texts?category=${categoryId}&page=${page + 1}`} class="btn-secondary text-sm !px-3 !py-1.5">
                        Succ &rarr;
                      </a>
                    )}
                  </div>
                </div>
              )}
            </div>
          </div>
        ) : (
          <div class="flex items-center justify-center h-64">
            <p class="text-gray-400 dark:text-gray-500">Seleziona una categoria dalla sidebar</p>
          </div>
        )}
      </div>
    </div>
  </div>

  <script define:vars={{ categoryId }}>
    // Ricerca categorie
    document.getElementById('catSearch')?.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      document.querySelectorAll('#catList a').forEach(el => {
        const name = el.getAttribute('data-cat-name') || '';
        el.style.display = name.includes(query) ? '' : 'none';
      });
    });

    // Telegram Preview
    const contentInput = document.getElementById('contentInput');
    const previewBox = document.getElementById('preview-box');
    const previewText = document.getElementById('preview-text');
    if (contentInput && previewBox && previewText) {
      contentInput.addEventListener('input', () => {
        const val = contentInput.value.trim();
        if (!val) { previewBox.classList.add('hidden'); return; }
        previewBox.classList.remove('hidden');
        previewText.textContent = val
          .replace(/\{name\}/g, 'Mario')
          .replace(/\{name1\}/g, 'Luigi')
          .replace(/\{name2\}/g, 'Peach');
      });
    }

    // Aggiungi frase
    document.getElementById('addForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const content = form.content.value.trim();
      if (!content) return;
      const res = await fetch('/api/content/texts', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ category_id: categoryId, content }),
      });
      if (res.ok) window.location.reload();
    });

    // Bulk import toggle
    const btnBulk = document.getElementById('btn-bulk');
    const bulkForm = document.getElementById('bulk-form');
    if (btnBulk && bulkForm) {
      btnBulk.addEventListener('click', () => {
        bulkForm.classList.toggle('hidden');
      });
    }

    // Bulk import: count lines
    const bulkContent = document.getElementById('bulkContent');
    const bulkCount = document.getElementById('bulk-count');
    if (bulkContent && bulkCount) {
      bulkContent.addEventListener('input', () => {
        const format = document.querySelector('input[name="bulkFormat"]:checked')?.value;
        let count = 0;
        try {
          if (format === 'json') {
            const arr = JSON.parse(bulkContent.value);
            count = Array.isArray(arr) ? arr.filter(s => typeof s === 'string' && s.trim()).length : 0;
          } else {
            count = bulkContent.value.split('\n').filter(s => s.trim()).length;
          }
        } catch { count = 0; }
        bulkCount.textContent = count + ' frasi rilevate';
      });
    }

    // Bulk import: submit
    document.getElementById('btn-bulk-import')?.addEventListener('click', async () => {
      const format = document.querySelector('input[name="bulkFormat"]:checked')?.value || 'text';
      const raw = bulkContent?.value?.trim();
      if (!raw) return;
      const statusEl = document.getElementById('bulk-status');

      let items;
      if (format === 'json') {
        try { items = JSON.parse(raw); } catch { statusEl.textContent = 'JSON non valido'; statusEl.className = 'text-sm px-3 py-2 rounded-xl bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400'; return; }
      } else {
        items = raw;
      }

      statusEl.textContent = 'Importazione in corso...';
      statusEl.className = 'text-sm px-3 py-2 rounded-xl bg-yellow-50 dark:bg-yellow-900/30 text-yellow-600 dark:text-yellow-400';

      const res = await fetch('/api/content/bulk-import', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ category_id: categoryId, items, format }),
      });

      if (res.ok) {
        const data = await res.json();
        statusEl.textContent = `Importate ${data.imported} frasi con successo!`;
        statusEl.className = 'text-sm px-3 py-2 rounded-xl bg-green-50 dark:bg-green-900/30 text-green-600 dark:text-green-400';
        setTimeout(() => window.location.reload(), 1500);
      } else {
        const data = await res.json();
        statusEl.textContent = data.error || 'Errore durante importazione';
        statusEl.className = 'text-sm px-3 py-2 rounded-xl bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400';
      }
    });

    // Elimina
    document.querySelectorAll('[data-delete]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-delete');
        if (!confirm('Sei sicuro di voler eliminare questa frase?')) return;
        const res = await fetch(`/api/content/texts?id=${id}`, { method: 'DELETE' });
        if (res.ok) window.location.reload();
      });
    });
  </script>
</Layout>
