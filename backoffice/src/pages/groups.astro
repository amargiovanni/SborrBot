---
import Layout from '../layouts/Layout.astro';
import { getGroups, getGroupStats } from '../lib/db';

const env = (Astro.locals as any).runtime?.env;
const url = new URL(Astro.request.url);
const page = Number(url.searchParams.get('page')) || 1;

let groups: any[] = [];
let total = 0;
let stats = { total: 0, active: 0, paused: 0, banned: 0 };

if (env?.DB) {
  const [result, groupStats] = await Promise.all([
    getGroups(env.DB, page),
    getGroupStats(env.DB),
  ]);
  groups = result.items as any[];
  total = result.total;
  if (groupStats) stats = groupStats;
}

const totalPages = Math.ceil(total / 20);

function formatDate(dateStr: string | null) {
  if (!dateStr) return '-';
  try {
    const d = new Date(dateStr + 'Z');
    return d.toLocaleDateString('it-IT', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
  } catch { return dateStr; }
}
---

<Layout title="Gruppi">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-semibold text-gray-800 dark:text-white/90">Gestione Gruppi</h1>
      <p class="text-theme-sm text-gray-500 dark:text-gray-400 mt-1">Gruppi Telegram dove il bot e' attivo</p>
    </div>

    <!-- Stat cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03] border-l-4 border-l-success-500">
        <div class="text-2xl font-bold text-gray-800 dark:text-white/90">{stats.active}</div>
        <div class="text-gray-500 dark:text-gray-400 text-theme-xs mt-1">Gruppi attivi</div>
      </div>
      <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03] border-l-4 border-l-warning-500">
        <div class="text-2xl font-bold text-gray-800 dark:text-white/90">{stats.paused}</div>
        <div class="text-gray-500 dark:text-gray-400 text-theme-xs mt-1">In pausa</div>
      </div>
      <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03] border-l-4 border-l-error-500">
        <div class="text-2xl font-bold text-gray-800 dark:text-white/90">{stats.banned}</div>
        <div class="text-gray-500 dark:text-gray-400 text-theme-xs mt-1">Bannati</div>
      </div>
    </div>

    <!-- Table -->
    <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white px-4 pb-3 pt-4 dark:border-gray-800 dark:bg-white/[0.03] sm:px-6">
      <table class="w-full">
        <thead>
          <tr class="border-y border-gray-100 dark:border-gray-800">
            <th class="py-3 text-left font-medium text-gray-500 text-theme-xs dark:text-gray-400">Gruppo</th>
            <th class="py-3 text-left font-medium text-gray-500 text-theme-xs dark:text-gray-400">Stato</th>
            <th class="py-3 text-left font-medium text-gray-500 text-theme-xs dark:text-gray-400">Ultimo aggiornamento</th>
            <th class="py-3 text-right font-medium text-gray-500 text-theme-xs dark:text-gray-400">Azioni</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
          {groups.length > 0 ? groups.map((group: any) => (
            <tr class="hover:bg-gray-50 dark:hover:bg-white/[0.02] transition-colors">
              <td class="py-3">
                <div class="text-theme-sm font-medium text-gray-800 dark:text-white/90">{group.title || 'Senza nome'}</div>
                <div class="text-theme-xs text-gray-400 dark:text-gray-500 font-mono mt-0.5">{group.telegram_chat_id}</div>
              </td>
              <td class="py-3">
                {group.is_banned ? (
                  <span class="inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-theme-xs font-medium bg-error-50 dark:bg-error-500/15 text-error-600 dark:text-error-500">
                    <span class="w-1.5 h-1.5 rounded-full bg-error-500"></span> Bannato
                  </span>
                ) : group.is_active ? (
                  <span class="inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-theme-xs font-medium bg-success-50 dark:bg-success-500/15 text-success-600 dark:text-success-500">
                    <span class="w-1.5 h-1.5 rounded-full bg-success-500"></span> Attivo
                  </span>
                ) : (
                  <span class="inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-theme-xs font-medium bg-warning-50 dark:bg-warning-500/15 text-warning-600 dark:text-warning-500">
                    <span class="w-1.5 h-1.5 rounded-full bg-warning-500"></span> In pausa
                  </span>
                )}
              </td>
              <td class="py-3 text-theme-sm text-gray-500 dark:text-gray-400">{formatDate(group.updated_at)}</td>
              <td class="py-3 text-right">
                <div class="flex gap-3 justify-end">
                  <button
                    data-toggle={group.id}
                    data-active={group.is_active}
                    class="text-theme-sm font-medium text-brand-500 hover:text-brand-600 transition-colors"
                  >
                    {group.is_active ? 'Pausa' : 'Attiva'}
                  </button>
                  <button
                    data-ban={group.id}
                    data-banned={group.is_banned}
                    class={`text-theme-sm font-medium transition-colors ${
                      group.is_banned
                        ? 'text-success-600 hover:text-success-700 dark:text-success-500 dark:hover:text-success-400'
                        : 'text-error-600 hover:text-error-700 dark:text-error-500 dark:hover:text-error-400'
                    }`}
                  >
                    {group.is_banned ? 'Sbanna' : 'Banna'}
                  </button>
                </div>
              </td>
            </tr>
          )) : (
            <tr>
              <td colspan="4" class="py-12 text-center">
                <div class="text-4xl mb-3">👥</div>
                <p class="text-gray-500 dark:text-gray-400 font-medium">Nessun gruppo ancora registrato</p>
              </td>
            </tr>
          )}
        </tbody>
      </table>

      {totalPages > 1 && (
        <div class="pt-3 border-t border-gray-200 dark:border-gray-800 flex items-center justify-between">
          <span class="text-gray-500 dark:text-gray-400 text-theme-sm">{total} gruppi totali</span>
          <div class="flex items-center gap-2">
            {page > 1 && <a href={`/groups?page=${page - 1}`} class="px-3 py-1.5 text-theme-sm bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">&larr; Prec</a>}
            <span class="px-3 py-1.5 text-theme-sm text-gray-500 dark:text-gray-400 tabular-nums">{page}/{totalPages}</span>
            {page < totalPages && <a href={`/groups?page=${page + 1}`} class="px-3 py-1.5 text-theme-sm bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">Succ &rarr;</a>}
          </div>
        </div>
      )}
    </div>
  </div>

  <script>
    document.querySelectorAll('[data-toggle]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-toggle');
        const currentActive = btn.getAttribute('data-active') === '1';
        const res = await fetch('/api/groups', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, is_active: currentActive ? 0 : 1 }),
        });
        if (res.ok) window.location.reload();
      });
    });

    document.querySelectorAll('[data-ban]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-ban');
        const currentBanned = btn.getAttribute('data-banned') === '1';
        const action = currentBanned ? 'sbannare' : 'bannare';
        if (!confirm(`Sei sicuro di voler ${action} questo gruppo?`)) return;
        const res = await fetch('/api/groups', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, is_banned: currentBanned ? 0 : 1 }),
        });
        if (res.ok) window.location.reload();
      });
    });
  </script>
</Layout>
