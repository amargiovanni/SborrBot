---
import Layout from '../layouts/Layout.astro';
import { getScheduledMessages, getGroups } from '../lib/db';

const env = (Astro.locals as any).runtime?.env;
let messages: any[] = [];
let groups: any[] = [];

if (env?.DB) {
  const [msgResult, grpResult] = await Promise.all([
    getScheduledMessages(env.DB),
    getGroups(env.DB, 1, 100),
  ]);
  messages = (msgResult.results ?? []) as any[];
  groups = grpResult.items as any[];
}

const scheduleLabels: Record<string, string> = { once: 'Una volta', daily: 'Giornaliero', weekly: 'Settimanale' };
const dayLabels = ['Dom', 'Lun', 'Mar', 'Mer', 'Gio', 'Ven', 'Sab'];

function formatSchedule(msg: any) {
  if (msg.schedule_type === 'once') return msg.scheduled_at?.replace('T', ' ') ?? '-';
  const time = msg.scheduled_at ?? '--:--';
  if (msg.schedule_type === 'weekly') return `${dayLabels[msg.day_of_week] ?? '?'} ${time}`;
  return `Ogni giorno ${time}`;
}
---

<Layout title="Scheduler">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-semibold text-gray-800 dark:text-white/90">Scheduler</h1>
        <p class="text-theme-sm text-gray-500 dark:text-gray-400 mt-1">Programma messaggi broadcast ai gruppi</p>
      </div>
      <button
        id="btn-new"
        class="btn-primary"
      >
        + Nuovo Messaggio
      </button>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03] md:p-6 border-l-4 border-l-brand-500">
        <div class="text-2xl font-bold text-gray-800 dark:text-white/90">{messages.length}</div>
        <div class="text-gray-500 dark:text-gray-400 text-theme-xs mt-1">Messaggi totali</div>
      </div>
      <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03] md:p-6 border-l-4 border-l-success-500">
        <div class="text-2xl font-bold text-gray-800 dark:text-white/90">{messages.filter((m: any) => m.is_active).length}</div>
        <div class="text-gray-500 dark:text-gray-400 text-theme-xs mt-1">Attivi</div>
      </div>
      <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03] md:p-6 border-l-4 border-l-violet-500">
        <div class="text-2xl font-bold text-gray-800 dark:text-white/90">{messages.filter((m: any) => m.schedule_type !== 'once').length}</div>
        <div class="text-gray-500 dark:text-gray-400 text-theme-xs mt-1">Ricorrenti</div>
      </div>
    </div>

    <!-- Table -->
    <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white px-4 pb-3 pt-4 dark:border-gray-800 dark:bg-white/[0.03] sm:px-6">
      <div class="flex flex-col gap-2 mb-4 sm:flex-row sm:items-center sm:justify-between">
        <h3 class="text-lg font-semibold text-gray-800 dark:text-white/90">
          Messaggi Programmati
        </h3>
      </div>

      <div class="w-full overflow-x-auto">
        <table class="min-w-full">
          <thead>
            <tr class="border-gray-200 border-y dark:border-gray-800">
              <th class="py-3 text-left">
                <p class="font-medium text-gray-500 text-theme-xs dark:text-gray-400">Messaggio</p>
              </th>
              <th class="py-3 text-left">
                <p class="font-medium text-gray-500 text-theme-xs dark:text-gray-400">Destinatario</p>
              </th>
              <th class="py-3 text-left">
                <p class="font-medium text-gray-500 text-theme-xs dark:text-gray-400">Pianificazione</p>
              </th>
              <th class="py-3 text-left">
                <p class="font-medium text-gray-500 text-theme-xs dark:text-gray-400">Stato</p>
              </th>
              <th class="py-3 text-right">
                <p class="font-medium text-gray-500 text-theme-xs dark:text-gray-400">Azioni</p>
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {messages.length > 0 ? messages.map((msg: any) => (
              <tr class="hover:bg-gray-100 dark:hover:bg-white/5 transition-colors" data-msg={JSON.stringify(msg)}>
                <td class="py-3">
                  <div class="flex items-center">
                    <p class="font-medium text-gray-800 text-theme-sm dark:text-white/90 max-w-xs truncate">{msg.message_text}</p>
                  </div>
                </td>
                <td class="py-3">
                  <div class="flex items-center">
                    <p class="text-gray-500 text-theme-sm dark:text-gray-400">
                      {msg.group_title ?? (msg.target_group_id ? msg.target_group_id : 'Tutti i gruppi')}
                    </p>
                  </div>
                </td>
                <td class="py-3">
                  <div class="flex items-center gap-2">
                    <span class={`rounded-full px-2 py-0.5 text-theme-xs font-medium ${
                      msg.schedule_type === 'once' ? 'bg-warning-50 px-2 py-0.5 text-warning-600 dark:bg-warning-500/15 dark:text-warning-500' :
                      msg.schedule_type === 'daily' ? 'bg-brand-50 text-brand-600 dark:bg-brand-500/15 dark:text-brand-500' :
                      'bg-violet-50 text-violet-600 dark:bg-violet-500/15 dark:text-violet-400'
                    }`}>
                      {scheduleLabels[msg.schedule_type] ?? msg.schedule_type}
                    </span>
                    <span class="text-theme-sm text-gray-500 dark:text-gray-400">{formatSchedule(msg)}</span>
                  </div>
                </td>
                <td class="py-3">
                  <div class="flex items-center">
                    {msg.is_active ? (
                      <p class="rounded-full bg-success-50 px-2 py-0.5 text-theme-xs font-medium text-success-600 dark:bg-success-500/15 dark:text-success-500 inline-flex items-center gap-1.5">
                        <span class="w-1.5 h-1.5 rounded-full bg-success-500"></span> Attivo
                      </p>
                    ) : (
                      <p class="rounded-full bg-gray-100 px-2 py-0.5 text-theme-xs font-medium text-gray-500 dark:bg-gray-800 dark:text-gray-400 inline-flex items-center gap-1.5">
                        <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span> Inattivo
                      </p>
                    )}
                  </div>
                </td>
                <td class="py-3 text-right">
                  <div class="flex gap-2 justify-end">
                    <button data-edit={msg.id} class="btn-secondary text-theme-xs px-3 py-1.5">
                      Modifica
                    </button>
                    <button data-toggle-active={msg.id} data-current-active={msg.is_active} class="btn-secondary text-theme-xs px-3 py-1.5">
                      {msg.is_active ? 'Pausa' : 'Attiva'}
                    </button>
                    <button data-delete={msg.id} class="btn-danger text-theme-xs px-3 py-1.5">
                      Elimina
                    </button>
                  </div>
                </td>
              </tr>
            )) : (
              <tr>
                <td colspan="5" class="px-5 py-12 text-center">
                  <div class="text-4xl mb-3">&#128197;</div>
                  <p class="text-gray-500 dark:text-gray-400 font-medium">Nessun messaggio programmato</p>
                  <p class="text-gray-400 dark:text-gray-500 text-theme-sm mt-1">Crea il primo messaggio schedulato</p>
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Modal -->
  <div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
    <div class="rounded-2xl border border-gray-200 bg-white shadow-theme-xl dark:border-gray-800 dark:bg-gray-900 w-full max-w-lg mx-4 p-5 md:p-6">
      <h2 id="modal-title" class="text-lg font-semibold text-gray-800 dark:text-white/90 mb-5">Nuovo Messaggio Schedulato</h2>
      <form id="scheduler-form" class="space-y-4">
        <input type="hidden" id="form-id" />

        <div>
          <label class="block text-theme-xs font-medium text-gray-500 dark:text-gray-400 mb-1.5">Messaggio</label>
          <textarea id="form-text" rows="3" required class="w-full input-field resize-none" placeholder="Testo del messaggio..."></textarea>
        </div>

        <div>
          <label class="block text-theme-xs font-medium text-gray-500 dark:text-gray-400 mb-1.5">Destinatario</label>
          <select id="form-group" class="w-full input-field">
            <option value="">Tutti i gruppi attivi</option>
            {groups.map((g: any) => (
              <option value={g.telegram_chat_id}>{g.title || g.telegram_chat_id}</option>
            ))}
          </select>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-theme-xs font-medium text-gray-500 dark:text-gray-400 mb-1.5">Tipo</label>
            <select id="form-type" class="w-full input-field">
              <option value="once">Una volta</option>
              <option value="daily">Giornaliero</option>
              <option value="weekly">Settimanale</option>
            </select>
          </div>

          <div id="day-field" class="hidden">
            <label class="block text-theme-xs font-medium text-gray-500 dark:text-gray-400 mb-1.5">Giorno</label>
            <select id="form-day" class="w-full input-field">
              <option value="1">Lunedi</option>
              <option value="2">Martedi</option>
              <option value="3">Mercoledi</option>
              <option value="4">Giovedi</option>
              <option value="5">Venerdi</option>
              <option value="6">Sabato</option>
              <option value="0">Domenica</option>
            </select>
          </div>
        </div>

        <div id="datetime-field">
          <label class="block text-theme-xs font-medium text-gray-500 dark:text-gray-400 mb-1.5" id="schedule-label">Data e ora</label>
          <input type="datetime-local" id="form-datetime" class="w-full input-field" />
          <input type="time" id="form-time" class="hidden w-full input-field" />
        </div>

        <div class="flex gap-3 pt-2">
          <button type="submit" class="btn-primary flex-1">
            Salva
          </button>
          <button type="button" id="btn-cancel" class="btn-secondary">
            Annulla
          </button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline>
    var modal = document.getElementById('modal');
    var form = document.getElementById('scheduler-form');
    var formId = document.getElementById('form-id');
    var formText = document.getElementById('form-text');
    var formGroup = document.getElementById('form-group');
    var formType = document.getElementById('form-type');
    var formDay = document.getElementById('form-day');
    var formDatetime = document.getElementById('form-datetime');
    var formTime = document.getElementById('form-time');
    var dayField = document.getElementById('day-field');
    var scheduleLabel = document.getElementById('schedule-label');
    var modalTitle = document.getElementById('modal-title');

    function openModal(msg) {
      if (msg) {
        modalTitle.textContent = 'Modifica Messaggio';
        formId.value = msg.id;
        formText.value = msg.message_text;
        formGroup.value = msg.target_group_id || '';
        formType.value = msg.schedule_type;
        if (msg.schedule_type === 'once') {
          formDatetime.value = msg.scheduled_at || '';
        } else {
          formTime.value = msg.scheduled_at || '';
        }
        if (msg.day_of_week !== null) formDay.value = msg.day_of_week;
      } else {
        modalTitle.textContent = 'Nuovo Messaggio Schedulato';
        formId.value = '';
        form.reset();
      }
      updateTypeFields();
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    function updateTypeFields() {
      var type = formType.value;
      var isOnce = type === 'once';
      var isWeekly = type === 'weekly';

      dayField.classList.toggle('hidden', !isWeekly);
      formDatetime.classList.toggle('hidden', !isOnce);
      formTime.classList.toggle('hidden', isOnce);
      scheduleLabel.textContent = isOnce ? 'Data e ora' : 'Orario (UTC)';
    }

    formType.addEventListener('change', updateTypeFields);
    document.getElementById('btn-new').addEventListener('click', function() { openModal(null); });
    document.getElementById('btn-cancel').addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      var id = formId.value;
      var isOnce = formType.value === 'once';
      var scheduledAt = isOnce ? formDatetime.value : formTime.value;

      var body = {
        message_text: formText.value,
        target_group_id: formGroup.value || null,
        schedule_type: formType.value,
        scheduled_at: scheduledAt,
        day_of_week: formType.value === 'weekly' ? Number(formDay.value) : null,
      };

      if (id) {
        body.id = Number(id);
        body.is_active = 1;
        await fetch('/api/scheduler', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
      } else {
        await fetch('/api/scheduler', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
      }
      window.location.reload();
    });

    // Edit buttons
    document.querySelectorAll('[data-edit]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var row = btn.closest('tr');
        var msg = JSON.parse(row.getAttribute('data-msg'));
        openModal(msg);
      });
    });

    // Toggle active
    document.querySelectorAll('[data-toggle-active]').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        var row = btn.closest('tr');
        var msg = JSON.parse(row.getAttribute('data-msg'));
        msg.is_active = msg.is_active ? 0 : 1;
        await fetch('/api/scheduler', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(msg),
        });
        window.location.reload();
      });
    });

    // Delete buttons
    document.querySelectorAll('[data-delete]').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        if (!confirm('Eliminare questo messaggio schedulato?')) return;
        var id = btn.getAttribute('data-delete');
        await fetch('/api/scheduler?id=' + id, { method: 'DELETE' });
        window.location.reload();
      });
    });
  </script>
</Layout>
