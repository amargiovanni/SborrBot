---
import Layout from '../layouts/Layout.astro';
import { getScheduledMessages, getGroups } from '../lib/db';

const env = (Astro.locals as any).runtime?.env;
let messages: any[] = [];
let groups: any[] = [];

if (env?.DB) {
  const [msgResult, grpResult] = await Promise.all([
    getScheduledMessages(env.DB),
    getGroups(env.DB, 1, 100),
  ]);
  messages = (msgResult.results ?? []) as any[];
  groups = grpResult.items as any[];
}

const scheduleLabels: Record<string, string> = { once: 'Una volta', daily: 'Giornaliero', weekly: 'Settimanale' };
const dayLabels = ['Dom', 'Lun', 'Mar', 'Mer', 'Gio', 'Ven', 'Sab'];

function formatSchedule(msg: any) {
  if (msg.schedule_type === 'once') return msg.scheduled_at?.replace('T', ' ') ?? '-';
  const time = msg.scheduled_at ?? '--:--';
  if (msg.schedule_type === 'weekly') return `${dayLabels[msg.day_of_week] ?? '?'} ${time}`;
  return `Ogni giorno ${time}`;
}
---

<Layout title="Scheduler">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Scheduler</h1>
        <p class="text-gray-500 dark:text-gray-400 mt-1">Programma messaggi broadcast ai gruppi</p>
      </div>
      <button
        id="btn-new"
        class="px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium rounded-xl transition-colors"
      >
        + Nuovo Messaggio
      </button>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm p-5 border border-gray-100 dark:border-gray-800 border-l-4 border-l-blue-500">
        <div class="text-2xl font-bold text-gray-900 dark:text-white">{messages.length}</div>
        <div class="text-gray-500 dark:text-gray-400 text-xs mt-1">Messaggi totali</div>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm p-5 border border-gray-100 dark:border-gray-800 border-l-4 border-l-emerald-500">
        <div class="text-2xl font-bold text-gray-900 dark:text-white">{messages.filter((m: any) => m.is_active).length}</div>
        <div class="text-gray-500 dark:text-gray-400 text-xs mt-1">Attivi</div>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm p-5 border border-gray-100 dark:border-gray-800 border-l-4 border-l-violet-500">
        <div class="text-2xl font-bold text-gray-900 dark:text-white">{messages.filter((m: any) => m.schedule_type !== 'once').length}</div>
        <div class="text-gray-500 dark:text-gray-400 text-xs mt-1">Ricorrenti</div>
      </div>
    </div>

    <!-- Table -->
    <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-gray-100 dark:border-gray-800 text-left">
            <th class="px-5 py-3.5 text-gray-500 dark:text-gray-400 text-xs font-medium uppercase tracking-wider">Messaggio</th>
            <th class="px-5 py-3.5 text-gray-500 dark:text-gray-400 text-xs font-medium uppercase tracking-wider">Destinatario</th>
            <th class="px-5 py-3.5 text-gray-500 dark:text-gray-400 text-xs font-medium uppercase tracking-wider">Pianificazione</th>
            <th class="px-5 py-3.5 text-gray-500 dark:text-gray-400 text-xs font-medium uppercase tracking-wider">Stato</th>
            <th class="px-5 py-3.5 text-gray-500 dark:text-gray-400 text-xs font-medium uppercase tracking-wider text-right">Azioni</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50 dark:divide-gray-800">
          {messages.length > 0 ? messages.map((msg: any) => (
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/30 transition-colors" data-msg={JSON.stringify(msg)}>
              <td class="px-5 py-4">
                <div class="text-sm text-gray-900 dark:text-white max-w-xs truncate">{msg.message_text}</div>
              </td>
              <td class="px-5 py-4">
                <span class="text-sm text-gray-600 dark:text-gray-400">
                  {msg.group_title ?? (msg.target_group_id ? msg.target_group_id : 'Tutti i gruppi')}
                </span>
              </td>
              <td class="px-5 py-4">
                <div class="flex items-center gap-2">
                  <span class={`text-[10px] px-2 py-0.5 rounded-full font-medium ${
                    msg.schedule_type === 'once' ? 'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400' :
                    msg.schedule_type === 'daily' ? 'bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400' :
                    'bg-violet-50 dark:bg-violet-900/30 text-violet-600 dark:text-violet-400'
                  }`}>
                    {scheduleLabels[msg.schedule_type] ?? msg.schedule_type}
                  </span>
                  <span class="text-sm text-gray-500 dark:text-gray-400">{formatSchedule(msg)}</span>
                </div>
              </td>
              <td class="px-5 py-4">
                {msg.is_active ? (
                  <span class="inline-flex items-center gap-1.5 text-xs px-2.5 py-1 rounded-lg font-medium bg-green-50 dark:bg-green-900/30 text-green-600 dark:text-green-400">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Attivo
                  </span>
                ) : (
                  <span class="inline-flex items-center gap-1.5 text-xs px-2.5 py-1 rounded-lg font-medium bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400">
                    <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span> Inattivo
                  </span>
                )}
              </td>
              <td class="px-5 py-4 text-right">
                <div class="flex gap-2 justify-end">
                  <button data-edit={msg.id} class="text-xs px-3 py-1.5 rounded-lg font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
                    Modifica
                  </button>
                  <button data-toggle-active={msg.id} data-current-active={msg.is_active} class="text-xs px-3 py-1.5 rounded-lg font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
                    {msg.is_active ? 'Pausa' : 'Attiva'}
                  </button>
                  <button data-delete={msg.id} class="text-xs px-3 py-1.5 rounded-lg font-medium bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-800/40 transition-colors">
                    Elimina
                  </button>
                </div>
              </td>
            </tr>
          )) : (
            <tr>
              <td colspan="5" class="px-5 py-12 text-center">
                <div class="text-4xl mb-3">&#128197;</div>
                <p class="text-gray-500 dark:text-gray-400 font-medium">Nessun messaggio programmato</p>
                <p class="text-gray-400 dark:text-gray-500 text-sm mt-1">Crea il primo messaggio schedulato</p>
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Modal -->
  <div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
    <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-xl border border-gray-200 dark:border-gray-800 w-full max-w-lg mx-4 p-6">
      <h2 id="modal-title" class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Nuovo Messaggio Schedulato</h2>
      <form id="scheduler-form" class="space-y-4">
        <input type="hidden" id="form-id" />

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Messaggio</label>
          <textarea id="form-text" rows="3" required class="w-full px-3.5 py-2.5 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none resize-none" placeholder="Testo del messaggio..."></textarea>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Destinatario</label>
          <select id="form-group" class="w-full px-3.5 py-2.5 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none">
            <option value="">Tutti i gruppi attivi</option>
            {groups.map((g: any) => (
              <option value={g.telegram_chat_id}>{g.title || g.telegram_chat_id}</option>
            ))}
          </select>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Tipo</label>
            <select id="form-type" class="w-full px-3.5 py-2.5 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none">
              <option value="once">Una volta</option>
              <option value="daily">Giornaliero</option>
              <option value="weekly">Settimanale</option>
            </select>
          </div>

          <div id="day-field" class="hidden">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Giorno</label>
            <select id="form-day" class="w-full px-3.5 py-2.5 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none">
              <option value="1">Lunedi</option>
              <option value="2">Martedi</option>
              <option value="3">Mercoledi</option>
              <option value="4">Giovedi</option>
              <option value="5">Venerdi</option>
              <option value="6">Sabato</option>
              <option value="0">Domenica</option>
            </select>
          </div>
        </div>

        <div id="datetime-field">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5" id="schedule-label">Data e ora</label>
          <input type="datetime-local" id="form-datetime" class="w-full px-3.5 py-2.5 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none" />
          <input type="time" id="form-time" class="hidden w-full px-3.5 py-2.5 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none" />
        </div>

        <div class="flex gap-3 pt-2">
          <button type="submit" class="flex-1 px-4 py-2.5 bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium rounded-xl transition-colors">
            Salva
          </button>
          <button type="button" id="btn-cancel" class="px-4 py-2.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-sm font-medium rounded-xl hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
            Annulla
          </button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline>
    var modal = document.getElementById('modal');
    var form = document.getElementById('scheduler-form');
    var formId = document.getElementById('form-id');
    var formText = document.getElementById('form-text');
    var formGroup = document.getElementById('form-group');
    var formType = document.getElementById('form-type');
    var formDay = document.getElementById('form-day');
    var formDatetime = document.getElementById('form-datetime');
    var formTime = document.getElementById('form-time');
    var dayField = document.getElementById('day-field');
    var scheduleLabel = document.getElementById('schedule-label');
    var modalTitle = document.getElementById('modal-title');

    function openModal(msg) {
      if (msg) {
        modalTitle.textContent = 'Modifica Messaggio';
        formId.value = msg.id;
        formText.value = msg.message_text;
        formGroup.value = msg.target_group_id || '';
        formType.value = msg.schedule_type;
        if (msg.schedule_type === 'once') {
          formDatetime.value = msg.scheduled_at || '';
        } else {
          formTime.value = msg.scheduled_at || '';
        }
        if (msg.day_of_week !== null) formDay.value = msg.day_of_week;
      } else {
        modalTitle.textContent = 'Nuovo Messaggio Schedulato';
        formId.value = '';
        form.reset();
      }
      updateTypeFields();
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    function updateTypeFields() {
      var type = formType.value;
      var isOnce = type === 'once';
      var isWeekly = type === 'weekly';

      dayField.classList.toggle('hidden', !isWeekly);
      formDatetime.classList.toggle('hidden', !isOnce);
      formTime.classList.toggle('hidden', isOnce);
      scheduleLabel.textContent = isOnce ? 'Data e ora' : 'Orario (UTC)';
    }

    formType.addEventListener('change', updateTypeFields);
    document.getElementById('btn-new').addEventListener('click', function() { openModal(null); });
    document.getElementById('btn-cancel').addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      var id = formId.value;
      var isOnce = formType.value === 'once';
      var scheduledAt = isOnce ? formDatetime.value : formTime.value;

      var body = {
        message_text: formText.value,
        target_group_id: formGroup.value || null,
        schedule_type: formType.value,
        scheduled_at: scheduledAt,
        day_of_week: formType.value === 'weekly' ? Number(formDay.value) : null,
      };

      if (id) {
        body.id = Number(id);
        body.is_active = 1;
        await fetch('/api/scheduler', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
      } else {
        await fetch('/api/scheduler', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
      }
      window.location.reload();
    });

    // Edit buttons
    document.querySelectorAll('[data-edit]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var row = btn.closest('tr');
        var msg = JSON.parse(row.getAttribute('data-msg'));
        openModal(msg);
      });
    });

    // Toggle active
    document.querySelectorAll('[data-toggle-active]').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        var row = btn.closest('tr');
        var msg = JSON.parse(row.getAttribute('data-msg'));
        msg.is_active = msg.is_active ? 0 : 1;
        await fetch('/api/scheduler', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(msg),
        });
        window.location.reload();
      });
    });

    // Delete buttons
    document.querySelectorAll('[data-delete]').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        if (!confirm('Eliminare questo messaggio schedulato?')) return;
        var id = btn.getAttribute('data-delete');
        await fetch('/api/scheduler?id=' + id, { method: 'DELETE' });
        window.location.reload();
      });
    });
  </script>
</Layout>
